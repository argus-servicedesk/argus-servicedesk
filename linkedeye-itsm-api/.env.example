# ═══════════════════════════════════════════════════════════
# LinkedEye ITSM Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://linkedeye:linkedeye@localhost:5432/linkedeye

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                   # Set in production; leave empty for local dev without auth

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Keycloak SSO (optional)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=linkedeye
KEYCLOAK_CLIENT_ID=linkedeye-backend
KEYCLOAK_CLIENT_SECRET=

# Observability
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100
GRAFANA_URL=http://grafana:3000
GRAFANA_API_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#incidents

# SMS Providers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MSG91_API_KEY=
MSG91_SENDER_ID=LinkedEye
KALEYRA_API_KEY=
KALEYRA_SENDER_ID=LinkedEye

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@linkedeye.finspot.in

# AI Services
OLLAMA_URL=http://ollama:11434
HF_TEI_URL=http://tei:8080
FLOWISE_URL=http://flowise:3000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ServiceNow (optional)
SNOW_INSTANCE=
SNOW_USER=
SNOW_PASSWORD=
