generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  ENGINEER
  OPERATOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum TeamMemberRole {
  LEAD
  MEMBER
  OBSERVER
}

enum IncidentState {
  NEW
  IN_PROGRESS
  ON_HOLD
  ESCALATED
  RESOLVED
  CLOSED
  CANCELLED
}

enum Impact {
  ENTERPRISE
  DEPARTMENT
  TEAM
  INDIVIDUAL
}

enum Urgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Priority {
  P1
  P2
  P3
  P4
}

enum IncidentSource {
  MANUAL
  PROMETHEUS
  GRAFANA
  API
  EMAIL
  VOICE
  SLACK
}

enum ChangeType {
  NORMAL
  STANDARD
  EMERGENCY
}

enum ChangeState {
