  STAGING
  DEV
}

// ─── MULTI-TENANT: ORGANIZATION ──────────────────────────

model Organization {
  id          String      @id @default(uuid())
  name        String      @unique
  slug        String      @unique
  environment Environment @default(PROD)
  serverIp    String?
  fqdn        String?
  description        String?
  preferredLanguage  String?     @default("en")
  mfaRequired Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users              User[]
  teams              Team[]
  incidents          Incident[]
  changes            Change[]
  problems           Problem[]
  configurationItems ConfigurationItem[]
  alerts             Alert[]
  integrations       Integration[]
  slaDefinitions     SLADefinition[]
  smsLogs            SMSLog[]
  voiceCallLogs      VoiceCallLog[]
  slackIntegrations  SlackIntegration[]
  auditLogs          AuditLog[]
  ciRelationships     CIRelationship[]
  networkConnections  NetworkConnection[]
  vendors             Vendor[]
  assetFinancials     AssetFinancial[]
  assetAllocations    AssetAllocation[]
  assetDisposals      AssetDisposal[]
  assetMovements      AssetMovement[]
  ipAddressInventory  IPAddressInventory[]
  software            Software[]
  softwareInstallations SoftwareInstallation[]
  softwareLicenses    SoftwareLicense[]
  computerComponents  ComputerComponent[]
  consumableItems     ConsumableItem[]
  sites               Site[]
  serviceCategories   ServiceCategory[]
  catalogItems        CatalogItem[]
  serviceRequests     ServiceRequest[]
  kbCategories        KBCategory[]
  kbArticles          KBArticle[]

  @@index([slug])
  @@index([isActive])
}

// ─── SITE MODEL ───────────────────────────────────────────

model Site {
  id               String   @id @default(uuid())
  name             String
  code             String
  organizationId   String
  location         String?
  city             String?
  state            String?
  country          String?  @default("IN")
  timezone         String?  @default("Asia/Kolkata")
  serverIp         String?
  sshPort          Int?     @default(4422)
  sshUser          String?  @default("finadmin")
  redisHost        String?
  redisPort        Int?     @default(6379)
  redisPass        String?
  prometheusUrl    String?
  grafanaUrl       String?
  grafanaApiKey    String?
  lokiUrl          String?
  metadata         Json?
  isActive         Boolean  @default(true)
  isPrimary        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id])
  assets           ConfigurationItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// ─── CORE MODELS ──────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  role              Role       @default(VIEWER)
  status            UserStatus @default(ACTIVE)
  department        String?
  jobTitle          String?
  timezone          String     @default("Asia/Kolkata")
  mfaEnabled        Boolean    @default(false)
  mfaSecret         String?
  lastLogin         DateTime?
  loginAttempts     Int        @default(0)
  lockedUntil       DateTime?
  passwordChangedAt DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  ssoProvider       String?
  ssoId             String?
  skills            String[]
  preferredLanguage String?    @default("en")
  organizationId    String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  organization         Organization?       @relation(fields: [organizationId], references: [id])
  sessions             Session[]
  teamMembers          TeamMember[]
  managedTeams         Team[]              @relation("TeamManager")
  createdIncidents     Incident[]          @relation("IncidentCreator")
  assignedIncidents    Incident[]          @relation("IncidentAssignee")
  createdChanges       Change[]            @relation("ChangeCreator")
  assignedChanges      Change[]            @relation("ChangeAssignee")
  createdProblems      Problem[]           @relation("ProblemCreator")
  assignedProblems     Problem[]           @relation("ProblemAssignee")
  approvals            Approval[]
  ownedCIs             ConfigurationItem[] @relation("CIOwner")
  workNotes            WorkNote[]
  activities           Activity[]
  attachments          Attachment[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  onCallSchedules      OnCallSchedule[]
  linkedIncidentChanges IncidentChange[]
  linkedIncidentProblems IncidentProblem[]
  mfa                   UserMfa?
  assetAllocations    AssetAllocation[]  @relation("AllocationUser")
  approvedDisposals   AssetDisposal[]    @relation("DisposalApprover")
  assetMovements      AssetMovement[]    @relation("MovementUser")
  createdServiceCategories ServiceCategory[] @relation("ServiceCategoryCreator")
  createdCatalogItems      CatalogItem[]     @relation("CatalogItemCreator")
  requestedServiceRequests ServiceRequest[]  @relation("ServiceRequestRequester")
  assignedServiceRequests  ServiceRequest[]  @relation("ServiceRequestAssignee")
  approvedServiceRequests  ServiceRequest[]  @relation("ServiceRequestApprover")
  assignedRequestItems     RequestItem[]     @relation("RequestItemAssignee")
  authoredKBArticles       KBArticle[]       @relation("KBArticleAuthor")
  reviewedKBArticles       KBArticle[]       @relation("KBArticleReviewer")
  kbFeedback               KBFeedback[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([organizationId])
}

model Session {
  id           String   @id @default(uuid())
  token        String   @unique
  refreshToken String   @unique
  userId       String
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Team {
  id             String  @id @default(uuid())
  name           String
  description    String?
  email          String?
  slackChannel   String?
  managerId      String?
  isActive       Boolean @default(true)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization?       @relation(fields: [organizationId], references: [id])
  manager            User?              @relation("TeamManager", fields: [managerId], references: [id])
  members            TeamMember[]
  assignedIncidents  Incident[]
  assignedChanges    Change[]
  assignedProblems   Problem[]
  supportedCIs       ConfigurationItem[] @relation("CISupportGroup")
  escalationPolicies EscalationPolicy[]
  onCallSchedules    OnCallSchedule[]
  catalogFulfillments  CatalogItem[]      @relation("CatalogFulfillment")
  serviceRequestGroups ServiceRequest[]   @relation("ServiceRequestGroup")

  @@unique([name, organizationId])
  @@index([name])
  @@index([organizationId])
}

model TeamMember {
  id       String         @id @default(uuid())
  teamId   String
  userId   String
  role     TeamMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ─── ITIL MODULES ─────────────────────────────────────────

model Incident {
  id                  String        @id @default(uuid())
  number              String        @unique
  shortDescription    String
  description         String?
  state               IncidentState @default(NEW)
  impact              Impact        @default(INDIVIDUAL)
  urgency             Urgency       @default(LOW)
  priority            Priority      @default(P4)
  category            String?
  subcategory         String?
  assignedToId        String?
  assignmentGroupId   String?
  createdById         String
  configItemId        String?
  slaBreached         Boolean       @default(false)
  responseTime        DateTime?
  resolutionTime      DateTime?
  slaTargetResponse   DateTime?
  slaTargetResolution DateTime?
  slaPausedAt         DateTime?
  slaPausedDuration   Int           @default(0)
  source              IncidentSource @default(MANUAL)
  sourceAlertId       String?
  sourceAlertName     String?
  resolvedAt          DateTime?
  closedAt            DateTime?
  resolutionCode      String?
  resolutionNotes     String?
  escalationLevel     Int           @default(0)
  lastEscalatedAt     DateTime?
  organizationId      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization    Organization?      @relation(fields: [organizationId], references: [id])
  assignedTo      User?              @relation("IncidentAssignee", fields: [assignedToId], references: [id])
  assignmentGroup Team?              @relation(fields: [assignmentGroupId], references: [id])
  createdBy       User               @relation("IncidentCreator", fields: [createdById], references: [id])
  configItem      ConfigurationItem? @relation(fields: [configItemId], references: [id])
  workNotes       WorkNote[]
  relatedAlerts   Alert[]
  attachments     Attachment[]
  activities      Activity[]
  linkedChanges   IncidentChange[]
  linkedProblems  IncidentProblem[]
  smsLogs         SMSLog[]
  escalationLogs  EscalationLog[]

  @@index([state])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([number])
  @@index([assignmentGroupId])
  @@index([slaBreached])
  @@index([organizationId])
  // Composite indexes for multi-column dashboard/list queries
  @@index([organizationId, state])
  @@index([organizationId, priority, state])
  @@index([organizationId, createdAt])
  @@index([organizationId, slaBreached])
}

model Change {
  id                  String      @id @default(uuid())
  number              String      @unique
  shortDescription    String
  description         String?
  type                ChangeType  @default(NORMAL)
  state               ChangeState @default(NEW)
  riskLevel           RiskLevel   @default(MEDIUM)
  category            String?
  assignedToId        String?
  assignmentGroupId   String?
  createdById         String
  justification       String?
  implementationPlan  String?
  rollbackPlan        String?
  testPlan            String?
  communicationPlan   String?
  plannedStartDate    DateTime?
  plannedEndDate      DateTime?
  actualStartDate     DateTime?
  actualEndDate       DateTime?
  affectedServices    String?
  downtime            Int?
  userImpact          String?
  gitRepoUrl          String?
  gitBranch           String?
  gitCommitHash       String?
  pullRequestUrl      String?
  reviewNotes         String?
  closureCode         ClosureCode?
  organizationId      String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id])
  assignedTo      User?            @relation("ChangeAssignee", fields: [assignedToId], references: [id])
  assignmentGroup Team?            @relation(fields: [assignmentGroupId], references: [id])
  createdBy       User             @relation("ChangeCreator", fields: [createdById], references: [id])
  approvals       Approval[]
  affectedCIs     ChangeCI[]
  workNotes       WorkNote[]
  attachments     Attachment[]
  activities      Activity[]
  linkedIncidents IncidentChange[]

  @@index([state])
  @@index([type])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([number])
  @@index([organizationId])
}

model Problem {
  id                 String       @id @default(uuid())
  number             String       @unique
  shortDescription   String
  description        String?
  state              ProblemState @default(NEW)
  priority           Priority     @default(P4)
  category           String?
  assignedToId       String?
  assignmentGroupId  String?
  createdById        String
  rootCause          String?
  rootCauseAnalysis  Json?
  workaround         String?
  workaroundEffective Boolean     @default(false)
  permanentFix       String?
  fixImplemented     Boolean      @default(false)
  relatedChangeId    String?
  isKnownError       Boolean      @default(false)
  knownErrorId       String?
  organizationId     String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id])
  assignedTo      User?            @relation("ProblemAssignee", fields: [assignedToId], references: [id])
  assignmentGroup Team?            @relation(fields: [assignmentGroupId], references: [id])
  createdBy       User             @relation("ProblemCreator", fields: [createdById], references: [id])
  workNotes       WorkNote[]
  attachments     Attachment[]
  activities      Activity[]
  linkedIncidents IncidentProblem[]

  @@index([state])
  @@index([priority])
  @@index([isKnownError])
  @@index([number])
  @@index([organizationId])
}

model Approval {
  id         String        @id @default(uuid())
  changeId   String
  approverId String
  state      ApprovalState @default(PENDING)
  comments   String?
  approvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  change   Change @relation(fields: [changeId], references: [id], onDelete: Cascade)
  approver User   @relation(fields: [approverId], references: [id])

  @@index([changeId])
  @@index([approverId])
}

// ─── CMDB ─────────────────────────────────────────────────

model ConfigurationItem {
  id                String   @id @default(uuid())
  name              String
  type              CIType
  status            CIStatus @default(PLANNED)
  category          String?
  subcategory       String?
  description       String?
  serialNumber      String?
  assetTag          String?
  manufacturer      String?
  model             String?
  version           String?
  location          String?
  rackPosition      String?
  dataCenter        String?
  ipAddress         String?
  macAddress        String?
  hostname          String?
  fqdn              String?
  cpu               String?
  memory            String?
  storage           String?
  os                String?
  osVersion         String?
  ownerId           String?
  supportGroupId    String?
  vendor            String?
  purchaseDate      DateTime?
  warrantyExpiry    DateTime?
  endOfLife         DateTime?
  endOfSupport      DateTime?
  purchaseCost      Float?
  monthlyCost       Float?
  costCenter        String?
  monitoringEnabled Boolean  @default(false)
  prometheusJob     String?
  grafanaDashboard  String?
  lokiLabels        String?
  environment       Environment?
  criticality       Criticality?
  rack              String?
  installationDate  DateTime?
  lastMaintenanceDate DateTime?
  firmwareVersion   String?
  organizationId    String?
  siteId            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization?  @relation(fields: [organizationId], references: [id])
  site         Site?          @relation(fields: [siteId], references: [id])
  owner        User?      @relation("CIOwner", fields: [ownerId], references: [id])
  supportGroup Team?      @relation("CISupportGroup", fields: [supportGroupId], references: [id])
  incidents    Incident[]
  changes      ChangeCI[]
  alerts       Alert[]
  activities   Activity[]
  parentRelationships    CIRelationship[] @relation("CIParent")
  childRelationships     CIRelationship[] @relation("CIChild")
  sourceConnections      NetworkConnection[] @relation("ConnectionSource")
  destinationConnections NetworkConnection[] @relation("ConnectionDest")
  financials             AssetFinancial?
  allocations            AssetAllocation[]
  disposal               AssetDisposal?
  movements              AssetMovement[]
  ipAddresses            IPAddressInventory[]
  components             ComputerComponent[]
  softwareInstallations  SoftwareInstallation[]

  @@index([type])
  @@index([status])
  @@index([name])
  @@index([organizationId])
  @@index([siteId])
}

model Alert {
  id             String        @id @default(uuid())
  alertId        String
  name           String
  severity       AlertSeverity
  status         AlertStatus   @default(FIRING)
  source         AlertSource   @default(PROMETHEUS)
  description    String?
  metric         String?
  currentValue   String?
  threshold      String?
  labels         String?
  annotations    String?
  configItemId   String?
  incidentId     String?
  firedAt        DateTime
  resolvedAt     DateTime?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  silenceUntil   DateTime?
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization?      @relation(fields: [organizationId], references: [id])
  configItem   ConfigurationItem? @relation(fields: [configItemId], references: [id])
  incident     Incident?          @relation(fields: [incidentId], references: [id])

  @@unique([alertId, organizationId])
  @@index([status])
  @@index([severity])
  @@index([firedAt])
  @@index([configItemId])
  @@index([organizationId])
  // Composite indexes for alert list + stats queries
  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([organizationId, firedAt])
}

// ─── SUPPORT MODELS ───────────────────────────────────────

model WorkNote {
  id         String         @id @default(uuid())
  content    String
  isInternal Boolean        @default(false)
  authorId   String
  source     WorkNoteSource @default(MANUAL)
  incidentId String?
  changeId   String?
  problemId  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  author   User      @relation(fields: [authorId], references: [id])
  incident Incident? @relation(fields: [incidentId], references: [id])
  change   Change?   @relation(fields: [changeId], references: [id])
  problem  Problem?  @relation(fields: [problemId], references: [id])

  @@index([incidentId])
  @@index([changeId])
  @@index([problemId])
  @@index([createdAt])
  @@index([authorId])
}

model Activity {
  id             String   @id @default(uuid())
  action         String
  description    String?
  oldValue       String?
  newValue       String?
  userId            String?
  incidentId        String?
  changeId          String?
  problemId         String?
  configItemId      String?
  serviceRequestId  String?
  createdAt         DateTime @default(now())

  user           User?              @relation(fields: [userId], references: [id])
  incident       Incident?          @relation(fields: [incidentId], references: [id])
  change         Change?            @relation(fields: [changeId], references: [id])
  problem        Problem?           @relation(fields: [problemId], references: [id])
  configItem     ConfigurationItem? @relation(fields: [configItemId], references: [id])
  serviceRequest ServiceRequest?    @relation(fields: [serviceRequestId], references: [id])

  @@index([incidentId])
  @@index([changeId])
  @@index([problemId])
  @@index([createdAt])
  @@index([userId])
  @@index([configItemId])
  @@index([serviceRequestId])
}

model Attachment {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  incidentId   String?
  changeId     String?
  problemId    String?
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy User      @relation(fields: [uploadedById], references: [id])
  incident   Incident? @relation(fields: [incidentId], references: [id])
  change     Change?   @relation(fields: [changeId], references: [id])
  problem    Problem?  @relation(fields: [problemId], references: [id])

  @@index([incidentId])
  @@index([changeId])
  @@index([problemId])
  @@index([uploadedById])
}

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean             @default(false)
  readAt    DateTime?
  channel   NotificationChannel @default(WEB)
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id              String   @id @default(uuid())
  organizationId  String?
  userId          String?
  action          String   // e.g. "incident.created", "user.role_changed", "integration.deleted"
  resourceType    String   // e.g. "Incident", "User", "Integration" (formerly entityType)
  resourceId      String   // ID of affected resource (formerly entityId)
  changes         Json?    // { before: {...}, after: {...} }
  ipAddress       String?
  userAgent       String?
  severity        String   @default("INFO")    // INFO, WARNING, CRITICAL
  status          String   @default("SUCCESS") // SUCCESS, FAILURE
  createdAt       DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([severity])
}

model SLADefinition {
  id                    String   @id @default(uuid())
  name                  String
  priority              Priority
  responseTimeMinutes   Int
  resolutionTimeMinutes Int
  businessHoursOnly     Boolean  @default(false)
  isActive              Boolean  @default(true)
  organizationId        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([priority, organizationId])
  @@index([organizationId])
}

model EscalationPolicy {
  id          String   @id @default(uuid())
  teamId      String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team  Team             @relation(fields: [teamId], references: [id])
  rules EscalationRule[]

  @@index([teamId])
}

model EscalationRule {
  id                String     @id @default(uuid())
  policyId          String
  level             Int
  delayMinutes      Int
  notifyType        NotifyType
  notifyTargets     String
  conditionPriority String?    // If set, rule only fires for this priority (e.g. 'P1')
  createdAt         DateTime   @default(now())

  policy EscalationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

model OnCallSchedule {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  startTime DateTime
  endTime   DateTime
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([teamId])
  @@index([startTime, endTime])
  @@index([userId])
}

model EscalationLog {
  id            String   @id @default(uuid())
  incidentId    String
  level         Int
  notifyType    String
  targetContact String
  targetUserId  String?
  targetName    String?
  status        String   // ATTEMPTED, DELIVERED, NO_ANSWER, BUSY, FAILED, ACKNOWLEDGED
  callSid       String?
  attemptedAt   DateTime @default(now())
  respondedAt   DateTime?
  notes         String?

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([attemptedAt])
}

// ─── LINKING TABLES ───────────────────────────────────────

model IncidentChange {
  id         String   @id @default(uuid())
  incidentId String
  changeId   String
  linkType   LinkType
  notes      String?
  linkedById String?
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  change   Change   @relation(fields: [changeId], references: [id], onDelete: Cascade)
  linkedBy User?    @relation(fields: [linkedById], references: [id])

  @@unique([incidentId, changeId])
}

model IncidentProblem {
  id         String          @id @default(uuid())
  incidentId String
  problemId  String
  linkType   ProblemLinkType
  notes      String?
  linkedById String?
  createdAt  DateTime        @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  problem  Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  linkedBy User?    @relation(fields: [linkedById], references: [id])

  @@unique([incidentId, problemId])
}

model ChangeCI {
  id             String @id @default(uuid())
  changeId       String
  configItemId   String
  impactType     String?
  createdAt      DateTime @default(now())

  change     Change            @relation(fields: [changeId], references: [id], onDelete: Cascade)
  configItem ConfigurationItem @relation(fields: [configItemId], references: [id])

  @@unique([changeId, configItemId])
}

// ─── COMMUNICATION ────────────────────────────────────────

model EmailQueue {
  id           String      @id @default(uuid())
  to           String
  subject      String
  body         String
  templateId   String?
  templateData Json?
  status       EmailStatus @default(PENDING)
  priority     Int         @default(5)
  attempts     Int         @default(0)
  lastError    String?
  sentAt       DateTime?
  scheduledAt  DateTime?
  createdAt    DateTime    @default(now())

  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
}

model SMSLog {
  id             String       @id @default(uuid())
  recipient      String
  message        String
  templateId     String?
  provider       SMSProvider
  status         String
  messageId      String?
  cost           Float?
  latency        Int?
  direction      SMSDirection @default(OUTBOUND)
  incidentId     String?
  organizationId String?
  createdAt      DateTime     @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  incident     Incident?     @relation(fields: [incidentId], references: [id])

  @@index([incidentId])
  @@index([createdAt])
  @@index([organizationId])
}

model VoiceCallLog {
  id               String         @id @default(uuid())
  callSid          String?
  direction        VoiceDirection
  callerNumber     String?
  callerName       String?
  handler          VoiceHandler   @default(AI_BOT)
  duration         Int?
  status           String?
  recordingUrl     String?
  transcript       String?
  sentiment        String?
  language         String?
  linkedIncidentId String?
  organizationId   String?
  createdAt        DateTime       @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([createdAt])
  @@index([organizationId])
}

// ─── INTEGRATIONS ─────────────────────────────────────────

model Integration {
  id             String            @id @default(uuid())
  name           String
  type           IntegrationType
  status         IntegrationStatus @default(INACTIVE)
  config         String?
  lastSyncAt     DateTime?
  syncStatus     String?
  errorMessage   String?
  organizationId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization?        @relation(fields: [organizationId], references: [id])
  webhooks     IntegrationWebhook[]

  @@index([type])
  @@index([status])
  @@index([organizationId])
}

model IntegrationWebhook {
  id            String   @id @default(uuid())
  integrationId String
  name          String
  url           String
  secret        String?
  events        String
  isActive      Boolean  @default(true)
  lastTriggered DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
}

model SlackIntegration {
  id             String  @id @default(uuid())
  workspaceId    String?
  workspaceName  String?
  botToken       String?
  accessToken    String?
  channelId      String?
  channelName    String?
  webhookUrl     String?
  isActive       Boolean @default(true)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// ─── SCHEDULING ───────────────────────────────────────────

model ScheduledJob {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  cronPattern String
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── MFA ──────────────────────────────────────────────────

model UserMfa {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret      String   // Base32-encoded TOTP secret
  backupCodes String   // JSON array of hashed backup codes
  enabledAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CMDB: CI RELATIONSHIPS ─────────────────────────────

model CIRelationship {
  id             String             @id @default(uuid())
  parentId       String
  childId        String
  type           CIRelationshipType
  description    String?
  organizationId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  parent       ConfigurationItem @relation("CIParent", fields: [parentId], references: [id], onDelete: Cascade)
  child        ConfigurationItem @relation("CIChild", fields: [childId], references: [id], onDelete: Cascade)
  organization Organization?     @relation(fields: [organizationId], references: [id])

  @@unique([parentId, childId, type])
  @@index([parentId])
  @@index([childId])
  @@index([organizationId])
}

// ─── CMDB: NETWORK CONNECTIONS ──────────────────────────

model NetworkConnection {
  id                  String   @id @default(uuid())
  sourceDeviceId      String
  destinationDeviceId String
  sourcePort          String?
  destPort            String?
  connectionType      String?
  bandwidth           String?
  vlan                String?
  description         String?
  organizationId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sourceDevice      ConfigurationItem @relation("ConnectionSource", fields: [sourceDeviceId], references: [id], onDelete: Cascade)
  destinationDevice ConfigurationItem @relation("ConnectionDest", fields: [destinationDeviceId], references: [id], onDelete: Cascade)
  organization      Organization?     @relation(fields: [organizationId], references: [id])

  @@index([sourceDeviceId])
  @@index([destinationDeviceId])
  @@index([organizationId])
}

// ─── CMDB: VENDORS ──────────────────────────────────────

model Vendor {
  id             String   @id @default(uuid())
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  contractNumber String?
  website        String?
  isActive       Boolean  @default(true)
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?    @relation(fields: [organizationId], references: [id])
  financials   AssetFinancial[]
  softwareLicenses SoftwareLicense[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

// ─── CMDB: ASSET FINANCIALS ─────────────────────────────

model AssetFinancial {
  id             String    @id @default(uuid())
  assetId        String    @unique
  purchaseDate   DateTime?
  invoiceNumber  String?
  quantity       Int?      @default(1)
  unitPrice      Float?
  totalPrice     Float?
  vendorId       String?
  warrantyExpiry DateTime?
  amcStartDate   DateTime?
  amcEndDate     DateTime?
  amcVendor      String?
  currency       String?   @default("INR")
  poNumber       String?
  supplierContact String?
  organizationId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  asset        ConfigurationItem @relation(fields: [assetId], references: [id], onDelete: Cascade)
  vendor       Vendor?           @relation(fields: [vendorId], references: [id])
  organization Organization?     @relation(fields: [organizationId], references: [id])

  @@index([assetId])
  @@index([vendorId])
  @@index([organizationId])
}

// ─── CMDB: ASSET ALLOCATION ─────────────────────────────

model AssetAllocation {
  id             String           @id @default(uuid())
  assetId        String
  customerName   String?
  assignedUserId String?
  allocationDate DateTime?
  returnDate     DateTime?
  status         AllocationStatus @default(ALLOCATED)
  notes          String?
  organizationId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  asset        ConfigurationItem @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedUser User?             @relation("AllocationUser", fields: [assignedUserId], references: [id])
  organization Organization?     @relation(fields: [organizationId], references: [id])

  @@index([assetId])
  @@index([assignedUserId])
  @@index([status])
  @@index([organizationId])
}

// ─── CMDB: ASSET DISPOSAL ───────────────────────────────

model AssetDisposal {
  id               String          @id @default(uuid())
  assetId          String          @unique
  disposalDate     DateTime?
  disposalQuantity Int?
  disposalValue    Float?
  disposalMethod   DisposalMethod?
  remarks          String?
  approvedById     String?
  organizationId   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  asset        ConfigurationItem @relation(fields: [assetId], references: [id], onDelete: Cascade)
  approvedBy   User?             @relation("DisposalApprover", fields: [approvedById], references: [id])
  organization Organization?     @relation(fields: [organizationId], references: [id])

  @@index([assetId])
  @@index([organizationId])
}

// ─── CMDB: ASSET MOVEMENT ───────────────────────────────

model AssetMovement {
  id             String    @id @default(uuid())
  assetId        String
  fromLocation   String?
  toLocation     String?
  movementDate   DateTime?
  movedById      String?
  reason         String?
  organizationId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  asset        ConfigurationItem @relation(fields: [assetId], references: [id], onDelete: Cascade)
  movedBy      User?             @relation("MovementUser", fields: [movedById], references: [id])
  organization Organization?     @relation(fields: [organizationId], references: [id])

  @@index([assetId])
  @@index([movedById])
  @@index([organizationId])
}

// ─── CMDB: IP ADDRESS INVENTORY ─────────────────────────

model IPAddressInventory {
  id             String          @id @default(uuid())
  ipAddress      String
  subnet         String?
  gateway        String?
  dnsName        String?
  assetId        String?
  status         IPAddressStatus @default(AVAILABLE)
  vlan           String?
  notes          String?
  organizationId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  asset        ConfigurationItem? @relation(fields: [assetId], references: [id])
  organization Organization?      @relation(fields: [organizationId], references: [id])

  @@unique([ipAddress, organizationId])
  @@index([status])
  @@index([assetId])
  @@index([organizationId])
}

// ─── SOFTWARE MANAGEMENT ──────────────────────────────────

model Software {
  id             String            @id @default(uuid())
  name           String
  publisher      String?
  category       SoftwareCategory  @default(OTHER)
  description    String?
  website        String?
  isOpenSource   Boolean           @default(false)
  organizationId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization   Organization?          @relation(fields: [organizationId], references: [id])
  versions       SoftwareVersion[]
  licenses       SoftwareLicense[]

  @@index([name])
  @@index([category])
  @@index([organizationId])
}

model SoftwareVersion {
  id             String   @id @default(uuid())
  softwareId     String
  version        String
  arch           String?  // x86_64, arm64, etc.
  releaseDate    DateTime?
  endOfSupport   DateTime?
  createdAt      DateTime @default(now())

  software       Software               @relation(fields: [softwareId], references: [id], onDelete: Cascade)
  installations  SoftwareInstallation[]

  @@unique([softwareId, version])
  @@index([softwareId])
}

model SoftwareInstallation {
  id             String   @id @default(uuid())
  assetId        String
  versionId      String
  installDate    DateTime @default(now())
  uninstallDate  DateTime?
  installedBy    String?
  licenseId      String?
  organizationId String?
  createdAt      DateTime @default(now())

  asset          ConfigurationItem @relation(fields: [assetId], references: [id], onDelete: Cascade)
  version        SoftwareVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  license        SoftwareLicense?  @relation(fields: [licenseId], references: [id])
  organization   Organization?     @relation(fields: [organizationId], references: [id])

  @@index([assetId])
  @@index([versionId])
  @@index([licenseId])
  @@index([organizationId])
}

model SoftwareLicense {
  id              String        @id @default(uuid())
  softwareId      String
  name            String
  serialKey       String?
  type            LicenseType   @default(PERPETUAL)
  status          LicenseStatus @default(ACTIVE)
  quantity        Int           @default(1)
  usedCount       Int           @default(0)
  purchaseDate    DateTime?
  expiryDate      DateTime?
  cost            Float?
  currency        String        @default("USD")
  vendorId        String?
  poNumber        String?
  notes           String?
  organizationId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  software        Software               @relation(fields: [softwareId], references: [id], onDelete: Cascade)
  vendor          Vendor?                @relation(fields: [vendorId], references: [id])
  organization    Organization?          @relation(fields: [organizationId], references: [id])
  installations   SoftwareInstallation[]

  @@index([softwareId])
  @@index([status])
  @@index([expiryDate])
  @@index([organizationId])
}

// ─── COMPUTER COMPONENTS ──────────────────────────────────

model ComputerComponent {
  id             String   @id @default(uuid())
  assetId        String
  componentType  String   // PROCESSOR, MEMORY, HARD_DRIVE, SSD, GRAPHICS_CARD, NETWORK_CARD, POWER_SUPPLY, MOTHERBOARD
  name           String
  manufacturer   String?
  model          String?
  serialNumber   String?
  capacity       String?  // e.g. "16 GB", "512 GB", "3.5 GHz"
  speed          String?  // e.g. "3200 MHz", "7200 RPM"
  interface      String?  // e.g. "PCIe 4.0", "SATA III", "DDR4"
  slot           String?  // e.g. "DIMM Slot 1", "PCIe x16 Slot 1"
  status         String   @default("INSTALLED") // INSTALLED, SPARE, DEFECTIVE, REMOVED
  notes          String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asset          ConfigurationItem @relation(fields: [assetId], references: [id], onDelete: Cascade)
  organization   Organization?     @relation(fields: [organizationId], references: [id])

  @@index([assetId])
  @@index([componentType])
  @@index([organizationId])
}

// ─── CONSUMABLES & CARTRIDGES ─────────────────────────────

model ConsumableItem {
  id              String         @id @default(uuid())
  name            String
  type            ConsumableType @default(OTHER_CONSUMABLE)
  manufacturer    String?
  model           String?        // cartridge model number
  compatibleWith  String?        // printer/device models
  stockTotal      Int            @default(0)
  stockUsed       Int            @default(0)
  stockMin        Int            @default(5) // alert threshold
  location        String?
  cost            Float?
  currency        String         @default("USD")
  notes           String?
  organizationId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization    Organization?         @relation(fields: [organizationId], references: [id])
  usageLogs       ConsumableUsageLog[]

  @@index([type])
  @@index([organizationId])
}

model ConsumableUsageLog {
  id             String   @id @default(uuid())
  consumableId   String
  assetId        String?  // which printer/device used it
  quantity       Int      @default(1)
  action         String   // USED, ADDED, RETURNED, DISPOSED
  performedBy    String?
  notes          String?
  createdAt      DateTime @default(now())

  consumable     ConsumableItem @relation(fields: [consumableId], references: [id], onDelete: Cascade)

  @@index([consumableId])
  @@index([createdAt])
}

// ─── SERVICE CATALOG & REQUESTS ──────────────────────────

enum ServiceRequestState {
  NEW
  APPROVAL
  APPROVED
  FULFILLMENT
  FULFILLED
  CLOSED
  CANCELLED
}

enum RequestItemState {
  PENDING
  APPROVED
  IN_PROGRESS
  FULFILLED
  CLOSED
  CANCELLED
}

enum CatalogItemType {
  HARDWARE
  SOFTWARE
  ACCESS
  GENERAL
  SERVICE
}

enum KBArticleState {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model ServiceCategory {
  id              String   @id @default(uuid())
  name            String
  description     String?
  icon            String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  organizationId  String?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdBy       User          @relation("ServiceCategoryCreator", fields: [createdById], references: [id])
  catalogItems    CatalogItem[]

  @@index([organizationId])
  @@index([isActive])
}

model CatalogItem {
  id                 String          @id @default(uuid())
  name               String
  shortDescription   String
  description        String?
  categoryId         String
  type               CatalogItemType @default(GENERAL)
  icon               String?
  price              Float?
  currency           String          @default("USD")
  approvalRequired   Boolean         @default(true)
  fulfillmentGroupId String?
  estimatedDays      Int?
  formSchema         Json?
  isActive           Boolean         @default(true)
  sortOrder          Int             @default(0)
  organizationId     String?
  createdById        String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organization      Organization?   @relation(fields: [organizationId], references: [id])
  createdBy         User            @relation("CatalogItemCreator", fields: [createdById], references: [id])
  category          ServiceCategory @relation(fields: [categoryId], references: [id])
  fulfillmentGroup  Team?           @relation("CatalogFulfillment", fields: [fulfillmentGroupId], references: [id])
  requestItems      RequestItem[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([isActive])
  @@index([type])
}

model ServiceRequest {
  id                String              @id @default(uuid())
  number            String              @unique
  shortDescription  String
  description       String?
  state             ServiceRequestState @default(NEW)
  priority          Priority            @default(P3)
  requestedById     String
  assignedToId      String?
  assignmentGroupId String?
  approvedById      String?
  approvedAt        DateTime?
  fulfilledAt       DateTime?
  closedAt          DateTime?
  cancelReason      String?
  organizationId    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
  requestedBy     User          @relation("ServiceRequestRequester", fields: [requestedById], references: [id])
  assignedTo      User?         @relation("ServiceRequestAssignee", fields: [assignedToId], references: [id])
  assignmentGroup Team?         @relation("ServiceRequestGroup", fields: [assignmentGroupId], references: [id])
  approvedBy      User?         @relation("ServiceRequestApprover", fields: [approvedById], references: [id])
  requestItems    RequestItem[]
  activities      Activity[]

  @@index([organizationId])
  @@index([state])
  @@index([requestedById])
  @@index([assignedToId])
  @@index([number])
  @@index([organizationId, state])
  @@index([organizationId, requestedById])
}

model RequestItem {
  id                String           @id @default(uuid())
  serviceRequestId  String
  catalogItemId     String
  state             RequestItemState @default(PENDING)
  quantity          Int              @default(1)
  formData          Json?
  notes             String?
  assignedToId      String?
  fulfilledAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  serviceRequest    ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  catalogItem       CatalogItem    @relation(fields: [catalogItemId], references: [id])
  assignedTo        User?          @relation("RequestItemAssignee", fields: [assignedToId], references: [id])

  @@index([serviceRequestId])
  @@index([catalogItemId])
  @@index([state])
}

// ─── KNOWLEDGE BASE ──────────────────────────────────────

model KBCategory {
  id              String   @id @default(uuid())
  name            String
  description     String?
  icon            String?
  sortOrder       Int      @default(0)
  parentId        String?
  isActive        Boolean  @default(true)
  organizationId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
  parent          KBCategory?   @relation("KBCategoryTree", fields: [parentId], references: [id])
  children        KBCategory[]  @relation("KBCategoryTree")
  articles        KBArticle[]

  @@index([organizationId])
  @@index([parentId])
}

model KBArticle {
  id              String         @id @default(uuid())
  title           String
  slug            String
  content         String
  excerpt         String?
  state           KBArticleState @default(DRAFT)
  categoryId      String?
  authorId        String
  reviewerId      String?
  tags            String[]
  viewCount       Int            @default(0)
  publishedAt     DateTime?
  archivedAt      DateTime?
  organizationId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
  category        KBCategory?   @relation(fields: [categoryId], references: [id])
  author          User          @relation("KBArticleAuthor", fields: [authorId], references: [id])
  reviewer        User?         @relation("KBArticleReviewer", fields: [reviewerId], references: [id])
  feedback        KBFeedback[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([state])
  @@index([categoryId])
  @@index([authorId])
  @@index([organizationId, state])
}

model KBFeedback {
  id          String   @id @default(uuid())
  articleId   String
  userId      String
  helpful     Boolean
  comment     String?
  createdAt   DateTime @default(now())

  article     KBArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@unique([articleId, userId])
  @@index([articleId])
}
