# Copy to .env and set strong values. Do not commit .env.
# Use a vault or secret manager in production (AWS Secrets Manager, Azure Key Vault, etc.).

DJANGO_SECRET_KEY=change-me-min-50-chars-random
# Optional: HS256 signing key for JWT (>= 32 bytes recommended). Defaults to DJANGO_SECRET_KEY.
# JWT_SIGNING_KEY=

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173

DB_ENGINE=django.db.backends.postgresql
DB_NAME=argus_servicedesk
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0

# Comma-separated IPs of reverse proxies trusted to set X-Forwarded-For (production).
# TRUSTED_PROXY_IPS=10.0.0.10,10.0.0.11

ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Required when DEBUG=false
ALERTMANAGER_URL=
