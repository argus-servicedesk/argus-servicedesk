DJANGO_ENV=dev
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ARGUS_DEFAULT_PROMETHEUS_URL=https://uatprometheus.finspot.in/
ARGUS_DEFAULT_GRAFANA_URL=https://uatgrafana.finspot.in/
ARGUS_DEFAULT_ENTITY_HOST=127.0.0.1
ARGUS_DEFAULT_ENTITY_PORT=8000

DB_ENGINE=django.db.backends.postgresql
DB_NAME=argus_servicedesk
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0

ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# AI Agent
AI_PROVIDER=nvidia
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=meta/llama-3.1-70b-instruct
AI_TIMEOUT=60

# Optional parity configs with old system
MYSQL_DB_HOST=
MYSQL_DB_PORT=
MYSQL_DB_USER=
MYSQL_DB_PASS=
NEO4J_HOST=
NEO4J_PORT=
NEO4J_USER=
NEO4J_PASS=
ELASTIC_HOST=
ELASTIC_PORT=
REDMINE_HOST=
REDMINE_AUTOMATION_USER=
REDMINE_AUTOMATION_PASS=
VAULT_HOST=
VAULT_PORT=
